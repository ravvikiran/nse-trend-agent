# Telegram Configuration
# Get these from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ============================================
# AI/LLM Configuration - Multi-Provider Support
# ============================================
# The system will automatically use available providers.
# If one fails, it falls back to the next.

# 1. OpenAI (GPT-4o-mini, GPT-4o)
# Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini  # or gpt-4o, gpt-4

# 2. Groq (Free tier available - Fast!)
# Get from https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-70b-versatile  # or llama-3.1-8b-instant

# 3. Anthropic (Claude)
# Get from https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-3-haiku-20240307

# 4. Google Gemini
# Get from https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_MODEL=gemini-1.5-flash
