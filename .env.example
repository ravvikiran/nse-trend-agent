# NSE Momentum Scanner - Environment Variables
# Copy this file to .env and fill in your values.

# ============================================
# Dhan Broker API (Free for account holders)
# ============================================
# Sign up at https://dhan.co
# Enable API at https://dhanhq.co

# Your Dhan client ID (visible in your Dhan app profile)
DHAN_CLIENT_ID=your_dhan_client_id

# Your Dhan trading PIN (4-6 digits, used for login)
DHAN_PIN=your_trading_pin

# Your TOTP secret key (base32 string from authenticator app setup)
# This is the secret key shown when you set up 2FA, NOT the 6-digit code.
# If you scanned a QR code, the secret is in the otpauth:// URL after "secret="
DHAN_TOTP_SECRET=your_totp_base32_secret

# Access token (auto-generated if PIN + TOTP are set — leave empty)
DHAN_ACCESS_TOKEN=

# ============================================
# Telegram Alerts
# ============================================
# Get bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Your chat ID (visit https://api.telegram.org/bot<TOKEN>/getUpdates after messaging your bot)
TELEGRAM_CHAT_ID=your_chat_id_here
