        "timeframe": "1D",
        "scan_interval_minutes": 15,
        "max_signals_per_strategy": 2,
        "enable_mtf_strategy": true
    },
    "scheduler": {
        "timezone": "Asia/Kolkata",
        "scan_time_hour": 15,
        "scan_time_minute": 0,
        "am_signal_time_hour": 10,
        "am_signal_time_minute": 0,
        "pm_signal_time_hour": 15,
        "pm_signal_time_minute": 0,
        "run_days": [1, 2, 3, 4, 5],
        "market_open_hour": 9,
        "market_open_minute": 15,
        "market_close_hour": 15,
        "market_close_minute": 30
    },
    "stocks": {
        "config_file": "config/stocks.json"
    },
    "reasoning": {
        "enabled": true,
        "weights": {
            "rule_based": 0,
            "ai_reasoning": 100
        },
        "ai_reasoning_enabled": true,
        "min_confidence_threshold": 60
    },
    "learning": {
        "enabled": true,
        "signal_tracking": {
            "check_interval_scans": 4,
            "expiry_days": 30,
            "auto_close_on_target": true,
            "auto_close_on_sl": true
        },
        "notifications": {
            "target_hit_alert": true,
            "sl_hit_alert": true,
            "batch_outcome_summary": true,
            "daily_report": true,
            "weekly_report": true
        },
        "siq_scoring": {
            "lookback_days": 30,
            "weights": {
                "win_rate": 0.25,
                "avg_return": 0.20,
