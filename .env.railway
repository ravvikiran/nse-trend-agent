# QuantGridIndia — Railway Environment Variables
# Set these in Railway dashboard → your service → Variables

# ============================================
# REQUIRED - Dhan Broker API
# ============================================
# Free API for all Dhan account holders.
# Sign up at https://dhan.co, enable API at https://dhanhq.co

# Your Dhan client ID (visible in your Dhan app profile)
DHAN_CLIENT_ID=your_dhan_client_id

# Your Dhan trading PIN (4-6 digit PIN used for login)
DHAN_PIN=your_dhan_pin

# Your TOTP secret key (base32 string from authenticator app setup)
# This is the secret key shown when you set up 2FA, NOT the 6-digit code.
# If you used a QR code, the secret is in the otpauth:// URL after "secret="
DHAN_TOTP_SECRET=your_totp_secret_base32

# Access token (auto-generated on startup — leave empty)
DHAN_ACCESS_TOKEN=

# ============================================
# REQUIRED - Telegram Alerts
# ============================================

# Your Telegram Bot Token (get from @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Your personal chat ID
# Visit: https://api.telegram.org/bot{TOKEN}/getUpdates
# after sending a message to your bot
TELEGRAM_CHAT_ID=your_chat_id_here

# ============================================
# OPTIONAL - Logging
# ============================================

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ============================================
# HOW TO GET CREDENTIALS
# ============================================

# Dhan:
#   1. Create account at https://dhan.co
#   2. Enable API at https://dhanhq.co
#   3. Client ID is in your Dhan app profile
#   4. PIN is your 4-6 digit trading PIN
#   5. TOTP secret: when setting up 2FA, copy the base32 key
#      (it looks like: JBSWY3DPEHPK3PXP)

# Telegram:
#   1. Open Telegram, search @BotFather
#   2. Send /newbot, follow instructions, copy the TOKEN
#   3. Message your new bot
#   4. Visit https://api.telegram.org/bot<TOKEN>/getUpdates
#   5. Find "id" in the response — that's your CHAT_ID

# ============================================
# DEPLOYMENT
# ============================================

# 1. Connect GitHub repo to Railway
# 2. Set all variables above in Railway dashboard
# 3. Deploy — scanner starts automatically as worker process
# 4. Token renews daily at 09:00 IST (no manual refresh needed)
