# Railway Environment Variables Template
# Copy these to your Railway dashboard > Variables

# ============================================
# REQUIRED - Telegram Configuration
# ============================================

# Your Telegram Bot Token (get from @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here_from_botfather

# Your personal chat ID (get from telegram API)
# Visit: https://api.telegram.org/bot{TOKEN}/getUpdates
# after sending a message to your bot
TELEGRAM_CHAT_ID=123456789

# ============================================
# OPTIONAL - Telegram Channel (for broadcasting)
# ============================================

# Channel chat ID (format: -100xxxxxxxx)
# Leave empty if you don't need channel broadcasting
TELEGRAM_CHANNEL_CHAT_ID=

# ============================================
# OPTIONAL - Stock Configuration
# ============================================

# JSON array of stocks to scan (comma-separated, no spaces)
# Default: Nifty 50 if not specified
STOCKS_LIST=["RELIANCE","TCS","HDFCBANK","INFY","ICICIBANK","SBIN","BHARTIARTL","LT","BAJFINANCE","HINDUNILVR"]

# ============================================
# OPTIONAL - Logging Configuration
# ============================================

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ============================================
# OPTIONAL - Advanced (usually not needed)
# ============================================

# Database URL (if using PostgreSQL)
# DATABASE_URL=postgresql://user:pass@host:port/db

# ============================================
# REQUIRED - Dhan Broker API (Momentum Scanner)
# ============================================
# Free API for all Dhan account holders.
# Get credentials from https://dhanhq.co

# Your Dhan client ID (visible in your Dhan app profile)
DHAN_CLIENT_ID=your_dhan_client_id

# Your Dhan trading PIN (4-6 digit PIN used for login)
DHAN_PIN=your_dhan_pin

# Your TOTP secret key (base32 string from authenticator app setup)
# This is the secret key shown when you set up 2FA, NOT the 6-digit code.
# If you used a QR code, the secret is in the otpauth:// URL after "secret="
DHAN_TOTP_SECRET=your_totp_secret_base32

# Access token (auto-generated on startup if PIN + TOTP are set)
# You can leave this empty — the scanner renews it automatically each morning.
# Or set it manually for the first run if you already have one.
DHAN_ACCESS_TOKEN=

# ============================================
# HOW TO GET TELEGRAM IDs
# ============================================

# 1. Create Bot:
#    - Open Telegram
#    - Search for @BotFather
#    - Type: /newbot
#    - Follow instructions
#    - Copy the TOKEN provided

# 2. Get Your Chat ID:
#    - Message your new bot
#    - Go to: https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates
#    - Look for "id" in the response
#    - That's your TELEGRAM_CHAT_ID

# 3. Get Channel ID (optional):
#    - Create a Telegram channel
#    - Add your bot as admin
#    - Send a message in channel
#    - Use the getUpdates endpoint above
#    - Channel ID format: -100xxxxxxxxxx

# ============================================
# STEP-BY-STEP SETUP
# ============================================

# Step 1: Create the bot
#   -> Go to BotFather, create bot, get token
#   -> Set TELEGRAM_BOT_TOKEN=<token>

# Step 2: Get your chat ID
#   -> Message the bot you just created
#   -> Visit getUpdates endpoint (see above)
#   -> Set TELEGRAM_CHAT_ID=<your_id>

# Step 3: Set stocks to monitor
#   -> Edit STOCKS_LIST with stocks you want
#   -> Must be valid NSE stock symbols

# Step 4: Add to Railway
#   -> Go to Railway.app
#   -> Create new project
#   -> Connect GitHub
#   -> Set these variables in Railway dashboard
#   -> Deploy

# ============================================
# EXAMPLE CONFIGURATIONS
# ============================================

# Example 1: Monitor Top 5 Stocks
# STOCKS_LIST=["RELIANCE","TCS","HDFCBANK","INFY","ICICIBANK"]

# Example 2: Monitor Specific Sector (IT)
# STOCKS_LIST=["TCS","INFY","WIPRO","HCL","MPHASIS"]

# Example 3: Monitor Bank Stocks
# STOCKS_LIST=["HDFCBANK","ICICIBANK","SBIN","AXISBANK","KOTAKBANK"]

# Example 4: All 50 stocks (Nifty 50 - default)
# Leave STOCKS_LIST empty or commented out
